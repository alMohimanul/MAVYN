# lemma configuration

# LLM Provider API Keys
# At least one is required for LLM features (ask, summarize, etc.)

# Primary provider (recommended)
GROQ_API_KEY=your_groq_api_key_here

# Backup provider
GEMINI_API_KEY=your_gemini_api_key_here

# Fallback provider
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Database configuration (optional)
# LEMMA_DB_PATH=~/.lemma/lemma.db

# Embedding model (optional, defaults to all-MiniLM-L6-v2)
# LEMMA_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Hugging Face token (optional, for faster downloads and higher rate limits)
# Get your token from: https://huggingface.co/settings/tokens
# HF_TOKEN=your_huggingface_token_here
